# Example environment variables for backend

# MongoDB Connection String
# For local development: mongodb://localhost:27017/furninest
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/furninest

# JWT Secret for token authentication (use a secure random string, min 32 characters)
JWT_SECRET=your_super_secure_jwt_secret_key_here_min_32_chars

# Server Port (Render will set this automatically, but you can specify)
PORT=5001

# Frontend URL for CORS configuration (set to your deployed frontend URL)
FRONTEND_URL=http://localhost:5174

# Node Environment
NODE_ENV=development
