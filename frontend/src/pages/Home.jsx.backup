import { useState, useEffect } from 'react';
import { Link, useNavigate } from 'react-router-dom';
import axios from 'axios';

const fallbackCategories = [
  { _id: '1', name: 'Chair', icon: '🪑' },
  { _id: '2', name: 'Table', icon: '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 1em; height: 1em; display: inline-block; vertical-align: middle;"><path d="M2 8L4.5 4H19.5L22 8H2Z" fill="#F59E0B" stroke="#000" stroke-width="1.5" stroke-linejoin="round"/><rect x="3.5" y="8" width="2" height="12" fill="#9CA3AF" stroke="#000" stroke-width="1.5"/><rect x="18.5" y="8" width="2" height="12" fill="#9CA3AF" stroke="#000" stroke-width="1.5"/><rect x="7.5" y="8" width="1.5" height="8" fill="#6B7280" stroke="#000" stroke-width="1.5"/><rect x="15" y="8" width="1.5" height="8" fill="#6B7280" stroke="#000" stroke-width="1.5"/></svg>' },
  { _id: '3', name: 'Bed', icon: '🛏️' },
  { _id: '4', name: 'Sofa', icon: '🛋️' },
  { _id: '5', name: 'Wardrobe', icon: '🚪' },
  { _id: '6', name: 'Bookshelf', icon: '📚' },
  { _id: '7', name: 'Others', icon: '📦' }
];

const Home = () => {
  const [categories, setCategories] = useState([]);
  const [recentListings, setRecentListings] = useState([]);
  const [searchQuery, setSearchQuery] = useState('');
  const [selectedCategory, setSelectedCategory] = useState('');
  const navigate = useNavigate();

  useEffect(() => {
    // Fetch categories
    axios.get('/api/categories')
      .then(res => setCategories(res.data))
      .catch(() => setCategories(fallbackCategories)); // Fallback if backend is down

    // Fetch recent listings
    axios.get('/api/listings/recent')
      .then(res => setRecentListings(res.data))
      .catch(err => console.error(err));
  }, []);

  const handleSearch = (e) => {
    e.preventDefault();
    navigate(`/browse?keyword=${searchQuery}&category=${selectedCategory}`);
  };

  return (
    <div>
      {/* Hero Section */}
      <section className="bg-white py-20 relative overflow-hidden">
        <div className="absolute top-0 left-0 w-full h-full bg-green-50 rounded-br-[150px] z-0 opacity-50"></div>
        <div className="container mx-auto px-4 relative z-10">
          <div className="max-w-3xl mx-auto text-center">
            <h1 className="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-6">
              Find the Perfect Furniture for Your <span style={{ color: 'var(--color-primary)' }}>Dream Home</span>
            </h1>
            <p className="text-lg text-gray-600 mb-10">
              Buy and sell high-quality, pre-owned and new furniture locally.
            </p>

            <form onSubmit={handleSearch} className="bg-white p-4 rounded-2xl shadow-lg flex flex-col md:flex-row gap-4 max-w-4xl mx-auto border border-gray-100">
              <input 
                type="text" 
                placeholder="What are you looking for? (e.g. Wooden Table)" 
                className="flex-grow px-4 py-3 rounded-xl border-2 border-gray-100 focus:outline-none focus:border-green-500 transition"
                value={searchQuery}
                onChange={e => setSearchQuery(e.target.value)}
              />
              <select 
                className="px-4 py-3 rounded-xl border-2 border-gray-100 focus:outline-none focus:border-green-500 bg-white md:w-64"
                value={selectedCategory}
                onChange={e => setSelectedCategory(e.target.value)}
              >
                <option value="">📂 All Categories</option>
                {categories.map(cat => (
                  <option key={cat._id} value={cat._id}>
                    {cat.name}
                  </option>
                ))}
              </select>
              <button type="submit" className="btn btn-primary px-8 py-3 text-lg rounded-xl whitespace-nowrap">
                Search
              </button>
            </form>
          </div>
        </div>
      </section>

      {/* Categories */}
      <section className="py-16 bg-gray-50">
        <div className="container mx-auto px-4">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-10">Browse by Category</h2>
          <div className="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-6">
            {categories.map(category => (
              <div key={category._id} onClick={() => navigate(`/browse?category=${category._id}`)} className="category-card text-center">
                <div className="category-icon-wrap text-4xl" dangerouslySetInnerHTML={{ __html: category.icon }}></div>
                <div className="category-name">{category.name}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Featured/Recent Listings */}
      <section className="py-20 bg-white">
        <div className="container mx-auto px-4">
          <div className="text-center mb-12">
            <h2 className="text-3xl font-bold text-gray-900 mb-4">Recent Listings</h2>
            <p className="text-gray-500">Specially curated premium furniture</p>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {recentListings.length > 0 ? recentListings.map(listing => (
              <div key={listing._id} className="listing-card">
                  {listing.isSold ? (
                    <span className="listing-badge" style={{ background: '#111827', color: '#fff' }}>sold</span>
                  ) : (
                    <span className="listing-badge">{listing.condition}</span>
                  )}
                <div className="listing-img-placeholder h-56 bg-gray-100 flex items-center justify-center text-6xl"
                  dangerouslySetInnerHTML={{ __html: listing.category?.icon || '🪑' }}>
                </div>
                <div className="listing-content p-5">
                  <h3 className="listing-title text-xl font-bold mb-2">{listing.title}</h3>
                  <div className="listing-price text-2xl font-bold text-green-700 mb-4">৳{listing.price}</div>
                  <div className="listing-meta flex justify-between text-gray-500 text-sm mb-4">
                    <span>📍 {listing.location}</span>
                    <span>{listing.category?.name}</span>
                  </div>
                  <Link to={`/listing/${listing._id}`} className="btn btn-outline w-full block text-center">View Details</Link>
                </div>
              </div>
            )) : (
              <div className="col-span-3 text-center text-gray-500 py-10">
                No recent listings found. Backend might not be seeded yet.
              </div>
            )}
          </div>
          
          <div className="text-center mt-12">
            <Link to="/browse" className="btn btn-primary px-8 py-3 text-lg rounded-xl inline-flex items-center gap-2">
              View All Furniture <span>→</span>
            </Link>
          </div>
        </div>
      </section>
    </div>
  );
};

export default Home;
