{
  "version": 2,
  "builds": [
    {
      "type": "vite",
      "src": "frontend/package.json",
      "config": {
        "include": ["frontend"]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_GOOGLE_CLIENT_ID": "@vite_google_client_id"
  }
}